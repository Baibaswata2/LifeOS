# Firebase Web SDK config — from Firebase Console > Project Settings > General > Your apps
# Copy this file to .env.local for local development.
# In production, set these in Vercel Dashboard > Project Settings > Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Messaging (push notifications) — from Firebase Console >
# Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=
